# Dockerfile for Qwen3-ASR serving with vLLM backend
FROM nvidia/cuda:12.1.0-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install system dependencies including deadsnakes PPA for Python 3.12
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.12 \
    python3.12-dev \
    python3.12-venv \
    git \
    wget \
    curl \
    libxcb1 \
    libxcb-render0 \
    libxcb-shape0 \
    libxcb-xfixes0 \
    libxrender1 \
    libsm6 \
    libxext6 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Set python3.12 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1 && \
    update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1

# Install pip for Python 3.12
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3.12
RUN python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel

# Install qwen-asr with vLLM backend support
# This includes all necessary dependencies including updated transformers
RUN pip install --no-cache-dir --ignore-installed blinker "qwen-asr[vllm]"

# Optional: Install flash-attention for better performance
# Uncomment if you have enough RAM (>96GB recommended) or set MAX_JOBS=4
# RUN pip install --no-cache-dir flash-attn --no-build-isolation

WORKDIR /app

# Default command - can be overridden in docker-compose
CMD ["qwen-asr-serve", "Qwen/Qwen3-ASR-1.7B", "--host", "0.0.0.0", "--port", "8000"]
